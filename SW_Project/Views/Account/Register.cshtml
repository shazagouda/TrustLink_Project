@model RegisterVM
@{
    ViewData["Title"] = "Create Account — TrustLink";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <style>

        :root {
            --navy: #0A1128;
            --navy-light: #1C2E5A;
            --gold: #C9A84C;
            --ivory: #FAF8F3;
            --text-muted: rgba(250,248,243,0.6);
            --transition: all 0.3s ease;
        }
        body {
            background: var(--navy);
            min-height: 100vh;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }
        .auth-page {
            display: flex;
            min-height: 100vh;
        }
        .auth-left {
            flex: 1.2;
            background: linear-gradient(135deg, #0A1128 0%, #0F1A3A 100%);
            padding: 3rem;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            position: relative;
            overflow: hidden;
        }
        .auth-left::before {
            content: '';
            position: absolute;
            top: -20%;
            right: -20%;
            width: 80%;
            height: 80%;
            background: radial-gradient(circle, rgba(201,168,76,0.08) 0%, transparent 70%);
            pointer-events: none;
        }
        .auth-left-content { position: relative; z-index: 1; }
        .auth-left-quote {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2.2rem;
            line-height: 1.3;
            color: var(--ivory);
            margin-bottom: 2rem;
            font-weight: 500;
        }
        .auth-left-quote em { color: var(--gold); font-style: italic; }
        .auth-left-features {
            list-style: none;
            padding: 0;
        }
        .auth-left-features li {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            font-size: 0.9rem;
            color: rgba(250,248,243,0.8);
            margin-bottom: 1rem;
        }
        .auth-left-features li i { color: var(--gold); width: 24px; }
        .auth-left-footer {
            font-size: 0.75rem;
            color: rgba(250,248,243,0.3);
        }
        .auth-right {
            flex: 0.9;
            background: var(--ivory);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }
        .auth-form-container {
            width: 100%;
            max-width: 440px;
        }
        .auth-form-header {
            margin-bottom: 2rem;
        }
        .auth-form-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2rem;
            font-weight: 600;
            color: var(--navy);
            margin-bottom: 0.5rem;
        }
        .auth-form-subtitle {
            font-size: 0.85rem;
            color: #666;
        }
        .auth-form-subtitle a {
            color: var(--gold);
            text-decoration: none;
            font-weight: 600;
        }
        .form-group-tl {
            margin-bottom: 1.25rem;
        }
        .form-label-tl {
            font-size: 0.8rem;
            font-weight: 600;
            color: var(--navy);
            margin-bottom: 0.5rem;
            display: block;
        }
        .form-input-tl {
            width: 100%;
            padding: 0.75rem 1rem;
            border: 1.5px solid #e0e0e0;
            border-radius: 12px;
            font-size: 0.9rem;
            transition: var(--transition);
            background: white;
        }
        .form-input-tl:focus {
            outline: none;
            border-color: var(--gold);
            box-shadow: 0 0 0 3px rgba(201,168,76,0.1);
        }
        .submit-btn-tl {
            width: 100%;
            padding: 0.85rem;
            background: var(--navy);
            color: white;
            border: none;
            border-radius: 12px;
            font-weight: 600;
            font-size: 0.95rem;
            cursor: pointer;
            transition: var(--transition);
            margin-top: 0.5rem;
        }
        .submit-btn-tl:hover {
            background: var(--navy-light);
            transform: translateY(-2px);
        }
        .validation-summary {
            background: #fee2e2;
            border-left: 4px solid #dc2626;
            padding: 0.75rem;
            border-radius: 8px;
            margin-bottom: 1rem;
        }
        .validation-summary ul {
            margin: 0;
            padding-left: 1.25rem;
        }
        .validation-summary li {
            font-size: 0.8rem;
            color: #b91c1c;
        }
        .terms-check {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin: 1rem 0;
        }
        .terms-check input {
            width: 16px;
            height: 16px;
            accent-color: var(--navy);
        }
        .terms-check label {
            font-size: 0.75rem;
            color: #666;
        }
        .terms-check a {
            color: var(--gold);
            text-decoration: none;
        }
    </style>
</head>
<body>
    <nav style="position:fixed;top:0;left:0;right:0;z-index:1000;padding:1.25rem 2rem;background:rgba(10,17,40,0.95);backdrop-filter:blur(10px);display:flex;align-items:center;justify-content:space-between;">
        <a href="/" style="font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:700;color:var(--ivory);text-decoration:none;">Trust<span style="color:var(--gold);">Link</span></a>
        <a href="/" style="font-size:0.83rem;color:rgba(250,248,243,0.5);text-decoration:none;"><i class="bi bi-arrow-left"></i> Back to Home</a>
    </nav>
    <div class="auth-page" style="padding-top:5rem;">
        <div class="auth-left d-none d-lg-flex">
            <div class="auth-left-content">
                <div style="font-size:0.72rem;font-weight:700;letter-spacing:0.18em;color:var(--gold);margin-bottom:1.5rem;">Join the Trust Network</div>
                <div class="auth-left-quote">Start your <em>secure</em> exchange journey today.</div>
                <ul class="auth-left-features mt-3">
                    <li><i class="bi bi-shield-check-fill"></i> Legally binding contracts</li>
                    <li><i class="bi bi-pen-fill"></i> Digital signatures</li>
                    <li><i class="bi bi-chat-dots-fill"></i> Secure messaging</li>
                </ul>
            </div>
            <div class="auth-left-footer">© 2024 TrustLink</div>
        </div>
        <div class="auth-right">
            <div class="auth-form-container">
                <div class="auth-form-header">
                    <div class="auth-form-title">Create account</div>
                    <div class="auth-form-subtitle">Already have an account? <a href="/Account/Login">Sign in</a></div>
                </div>
                <form method="post">
                    @Html.AntiForgeryToken()
                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.SelectMany(v => v.Errors).Any())
                    {
                        <div class="validation-summary">
                            <ul>
                                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                {
                                    <li>@error.ErrorMessage</li>
                                }
                            </ul>
                        </div>
                    }
                    <div class="form-group-tl">
                        <label class="form-label-tl">Full Name</label>
                        <input type="text" name="Name" class="form-input-tl" placeholder="Your full name" required autocomplete="name" value="@Model.Name">
                    </div>
                    <div class="form-group-tl">
                        <label class="form-label-tl">Email Address</label>
                        <input type="email" name="Email" class="form-input-tl" placeholder="you@example.com" required autocomplete="email" value="@Model.Email">
                    </div>
                    <div class="form-group-tl">
                        <label class="form-label-tl">Phone Number</label>
                        <input type="tel" name="PhoneNumber" class="form-input-tl" placeholder="+1 (555) 000-0000" autocomplete="tel" value="@Model.PhoneNumber">
                    </div>
                    <div class="form-group-tl">
                        <label class="form-label-tl">City / Area</label>
                        <input type="text" name="Location" class="form-input-tl" placeholder="Your city or area" autocomplete="address-level2" value="@Model.Location">
                    </div>
                    <div class="form-group-tl">
                        <label class="form-label-tl">Password</label>
                        <input type="password" name="Password" class="form-input-tl" placeholder="Minimum 8 characters" required autocomplete="new-password">
                    </div>
                    <div class="form-group-tl">
                        <label class="form-label-tl">Confirm Password</label>
                        <input type="password" name="ConfirmPassword" class="form-input-tl" placeholder="Repeat your password" required autocomplete="new-password">
                    </div>
                    <div class="terms-check">
                        <input type="checkbox" name="AgreeToTerms" value="true" required>
                        <label>I agree to TrustLink's <a href="#" target="_blank">Terms of Service</a>.</label>
                    </div>
                    <button type="submit" class="submit-btn-tl">Create My Account</button>
                </form>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>