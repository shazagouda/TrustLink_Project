@model List<SW_Project.Models.Favorite>
@using SW_Project.Models
@{
    ViewData["Title"] = "My Favorites — TrustLink";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/style.css">
    <style>
        .favorites-header {
            background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 100%);
            padding: 4rem 0;
            text-align: center;
            color: white;
            margin-bottom: 3rem;
        }
        .favorite-card { transition: all 0.3s ease; height: 100%; }
        .favorite-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-lg); }
        .remove-fav {
            position: absolute;
            top: 10px;
            right: 10px;
            background: rgba(255,255,255,0.9);
            border-radius: 50%;
            width: 32px;
            height: 32px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.2s;
            z-index: 5;
            color: #e74c3c;
        }
        .remove-fav:hover { background: #e74c3c; color: white; transform: scale(1.1); }
        .empty-favorites { text-align: center; padding: 4rem; background: var(--ivory); border-radius: var(--radius-lg); }
    </style>
</head>
<body>

    <nav class="tl-navbar navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" href="/">Trust<span>Link</span></a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav ms-auto me-4 gap-1">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Listings">Browse</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Favorites">Favorites</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Account/Profile">Profile</a></li>
                    <li class="nav-item"><a class="btn-nav-cta" href="/Account/Logout">Logout</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="favorites-header">
        <div class="container">
            <h1 class="display-hero" style="color: white;">My <em>Favorites</em></h1>
            <p class="lead">Items you've saved for later</p>
        </div>
    </div>

    <section class="profile-section" style="padding-top: 0;">
        <div class="container">
            @if (!Model.Any())
            {
                <div class="empty-favorites">
                    <i class="bi bi-heart" style="font-size: 4rem; color: var(--gold);"></i>
                    <h3 class="mt-3">Your favorites list is empty</h3>
                    <p class="text-muted">Explore listings and click the heart icon to save your favorites.</p>
                    <a href="/Listings" class="btn-primary-tl mt-3">Browse Listings</a>
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var fav in Model)
                    {
                        var listing = fav.Listing;
                        var firstImage = listing.ListingImages?.FirstOrDefault();
                        <div class="col-md-6 col-lg-4 favorite-card" data-listing-id="@listing.Id">
                            <div class="listing-card position-relative">
                                <div class="remove-fav" data-id="@listing.Id" title="Remove from favorites">
                                    <i class="bi bi-x-lg"></i>
                                </div>
                                <div class="listing-card-image">
                                    @if (firstImage != null)
                                    {
                                        <img src="@firstImage.ImagePath" alt="@listing.Title" style="width:100%; height:200px; object-fit:cover;">
                                    }
                                    else
                                    {
                                        <div class="listing-card-image-placeholder" style="height:200px;">
                                            <i class="bi @(listing.Category?.Icon ?? "bi-box")" style="font-size:3rem;"></i>
                                        </div>
                                    }
                                    <span class="listing-card-category">@(listing.Category?.Name ?? "General")</span>
                                </div>
                                <div class="listing-card-body">
                                    <div class="listing-card-title">@listing.Title</div>
                                    <div class="listing-card-location"><i class="bi bi-geo-alt"></i> @listing.Location</div>
                                    <div class="listing-card-footer mt-2">
                                        <div class="listing-card-price">$@listing.PricePerDay / day</div>
                                        <a href="/Listings/Details/@listing.Id" class="listing-card-btn">View Details</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </section>

    <footer class="tl-footer">...</footer>

    @* ✅ إضافة AntiForgeryToken لطلبات AJAX *@
    @Html.AntiForgeryToken()

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/script.js"></script>
    <script>
        function showToast(msg, icon = 'bi-check-circle-fill') {
            let existing = document.querySelector('.tl-toast');
            if (existing) existing.remove();
            const t = document.createElement('div');
            t.className = 'tl-toast';
            t.innerHTML = `<i class="bi ${icon}"></i><span>${msg}</span>`;
            document.body.appendChild(t);
            requestAnimationFrame(() => {
                requestAnimationFrame(() => t.classList.add('show'));
            });
            setTimeout(() => {
                t.classList.remove('show');
                setTimeout(() => t.remove(), 400);
            }, 3500);
        }

        document.querySelectorAll('.remove-fav').forEach(btn => {
            btn.addEventListener('click', async function(e) {
                e.preventDefault();
                e.stopPropagation();
                const listingId = this.dataset.id;
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                if (!token) {
                    console.error('Token missing');
                    return;
                }
                const formData = new FormData();
                formData.append('listingId', listingId);
                const response = await fetch('/Favorites/Remove', {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token },
                    body: formData
                });
                const result = await response.json();
                if (result.success) {
                    const card = document.querySelector(`.favorite-card[data-listing-id='${listingId}']`);
                    if (card) card.remove();
                    showToast('Removed from favorites');
                    if (document.querySelectorAll('.favorite-card').length === 0) {
                        location.reload();
                    }
                } else {
                    showToast(result.message, 'bi-x-circle');
                }
            });
        });
    </script>
</body>
</html>