<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TrustLink</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
</head>
<body>
    <nav class="tl-navbar navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">Trust<span>Link</span></a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#mainNav">
                <span class="visually-hidden">Toggle navigation</span>
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav ms-auto me-4 gap-1">
                    <li class="nav-item">
                        <a class="nav-link active" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="About">About</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="HowItWorks">How It Works</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Listings" asp-action="Index">Browse</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Contact" asp-action="Index">Contact us</a>
                    </li>
                    @if (User?.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a href="/Dashboard" class="nav-link">Dashboard</a>
                        </li>
      
                    }
                 
                </ul>

                <div class="d-flex gap-2">
                    <a asp-controller="Account" asp-action="Login" class="btn-outline-tl" style="padding:0.55rem 1.25rem; font-size:0.85rem;">Sign In</a>
                    <a asp-controller="Account" asp-action="Register" class="btn-primary-tl" style="padding:0.55rem 1.25rem; font-size:0.85rem;">Join Now</a>
                </div>
            </div>
        </div>
    </nav>

    @RenderBody()

    <footer class="tl-footer">
        <div class="container">
            <div class="row g-5">
                <div class="col-lg-4 col-md-6">
                    <a class="footer-brand" href="index.html">Trust<span>Link</span></a>
                    <p class="footer-desc">Smart resource sharing backed by legally binding digital contracts. Built for the modern trust economy.</p>
                </div>
                <div class="col-lg-2 col-md-3 col-6">
                    <div class="footer-heading">Platform</div>
                    <ul class="footer-links">
                        <li><a class="nav-link" asp-controller="Listings" asp-action="Index">Browse Listings</a></li>
                        <li> <a class="nav-link" asp-controller="Home" asp-action="HowItWorks">How It Works</a></li>
                        <li><a asp-controller="Account" asp-action="Login" class="btn-outline-tl" style="padding:0.55rem 1.25rem; font-size:0.85rem;">Sign In</a></li>
                        <li> <a asp-controller="Account" asp-action="Register" class="btn-primary-tl" style="padding:0.55rem 1.25rem; font-size:0.85rem;">Join Now</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-3 col-6">
                    <div class="footer-heading">Company</div>
                    <ul class="footer-links">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="About">About</a>
                        </li>
                        <li><a href="#">Careers</a></li>
                        <li><a href="#">Press</a></li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Contact" asp-action="Index">Contact</a>
                        </li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-3 col-6">
                    <div class="footer-heading">Legal</div>
                    <ul class="footer-links">
                        <li><a href="#">Privacy Policy</a></li>
                        <li><a href="#">Terms of Service</a></li>
                        <li><a href="#">Contract Terms</a></li>
                        <li><a href="#">Dispute Policy</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-3 col-6">
                    <div class="footer-heading">Support</div>
                    <ul class="footer-links">
                        <li><a href="#">Help Center</a></li>
                        <li><a href="#">Safety Tips</a></li>
                        <li><a href="#">Report an Issue</a></li>
                        <li><a href="#">Community</a></li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                <div class="footer-copyright">&copy; 2024 TrustLink. All rights reserved.</div>
                <div class="footer-social">
                    <a href="#" aria-label="Twitter"><i class="bi bi-twitter-x"></i></a>
                    <a href="#" aria-label="LinkedIn"><i class="bi bi-linkedin"></i></a>
                    <a href="#" aria-label="Instagram"><i class="bi bi-instagram"></i></a>
                    <a href="#" aria-label="GitHub"><i class="bi bi-github"></i></a>
                </div>
            </div>
        </div>
    </footer>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/script.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>