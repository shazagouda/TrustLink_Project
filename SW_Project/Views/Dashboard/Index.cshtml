@model SW_Project.ViewModels.Dashboard.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard — TrustLink";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/dashboard.css">

<div class="container py-4">
    <!-- Page header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="display-6" style="font-family: 'Cormorant Garamond', serif;">Welcome back, @Model.UserFirstName</h1>
            <p class="text-muted">Here is what is happening with your account today.</p>
        </div>
        <a href="/Listings/Create" class="btn-primary-tl">
            <i class="bi bi-plus-lg"></i> Post a Listing
        </a>
    </div>

    <!-- Stat Cards -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-card-icon navy"><i class="bi bi-card-list"></i></div>
                <div class="stat-card-body">
                    <span class="stat-card-label">Active Listings</span>
                    <span class="stat-card-value">@Model.ActiveListingsCount</span>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-card-icon gold"><i class="bi bi-file-earmark-check"></i></div>
                <div class="stat-card-body">
                    <span class="stat-card-label">Active Contracts</span>
                    <span class="stat-card-value">@Model.ActiveContractsCount</span>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-card-icon green"><i class="bi bi-calendar-check"></i></div>
                <div class="stat-card-body">
                    <span class="stat-card-label">Total Bookings</span>
                    <span class="stat-card-value">@Model.TotalBookingsCount</span>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card">
                <div class="stat-card-icon gold"><i class="bi bi-star"></i></div>
                <div class="stat-card-body">
                    <span class="stat-card-label">Trust Rating</span>
                    <span class="stat-card-value">@Model.UserRating.ToString("0.0")</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Bookings & Contracts -->
    <div class="row g-4">
        <div class="col-lg-7">
            <div class="dash-panel">
                <div class="dash-panel-header d-flex justify-content-between align-items-center">
                    <div class="dash-panel-title">Recent Bookings</div>
                    <a href="/Bookings/MyBookings" class="dash-panel-action">View All <i class="bi bi-arrow-right"></i></a>
                </div>
                @if (Model.RecentBookings != null && Model.RecentBookings.Any())
                {
                    <div class="table-responsive">
                        <table class="data-table">
                            <thead>
                                <tr><th>Listing</th><th>Dates</th><th>Status</th><th>Total</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var booking in Model.RecentBookings)
                                {
                                    <tr>
                                        <td class="td-title">@booking.ListingTitle</td>
                                        <td>@booking.StartDate.ToString("MMM dd") - @booking.EndDate.ToString("MMM dd")</td>
                                        <td><span class="status-badge @booking.Status.ToLower()"><span class="status-dot"></span>@booking.Status</span></td>
                                        <td>$@booking.TotalPrice</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="dash-empty-state">
                        <div class="dash-empty-icon"><i class="bi bi-calendar-x"></i></div>
                        <div class="dash-empty-title">No bookings yet</div>
                        <p class="dash-empty-desc">When you book a listing or receive a booking request, it will appear here.</p>
                        <a href="/Listings" class="btn-dash-primary">Browse Listings</a>
                    </div>
                }
            </div>
        </div>

        <div class="col-lg-5">
            <div class="dash-panel">
                <div class="dash-panel-header d-flex justify-content-between align-items-center">
                    <div class="dash-panel-title">Recent Contracts</div>
                    <a href="/Contracts/MyContracts" class="dash-panel-action">View All <i class="bi bi-arrow-right"></i></a>
                </div>
                @if (Model.RecentContracts != null && Model.RecentContracts.Any())
                {
                    @foreach (var contract in Model.RecentContracts)
                    {
                        <div class="d-flex justify-content-between align-items-center py-3 border-bottom">
                            <div>
                                <div class="fw-semibold">@contract.Title</div>
                                <div class="small text-muted">@contract.CreatedAt.ToString("MMMM dd, yyyy")</div>
                                <div class="small">with @contract.OtherPartyName</div>
                            </div>
                            <span class="status-badge @contract.Status.ToLower()"><span class="status-dot"></span>@contract.Status</span>
                        </div>
                    }
                }
                else
                {
                    <div class="dash-empty-state">
                        <div class="dash-empty-icon"><i class="bi bi-file-earmark-x"></i></div>
                        <div class="dash-empty-title">No contracts yet</div>
                        <p class="dash-empty-desc">Your signed digital contracts will appear here.</p>
                        <a href="/Contracts/Create" class="btn-dash-primary">Create Contract</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>


<script src="~/js/dashboard.js"></script>