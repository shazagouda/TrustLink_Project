@using SW_Project.ViewModels.Message
@model InboxVM
@{
    ViewData["Title"] = "Messages - TrustLink";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --navy: #0f1f3d;
            --gold: #c9a84c;
            --ivory: #faf8f3;
            --white: #ffffff;
            --border: rgba(15,31,61,0.12);
            --shadow-sm: 0 2px 12px rgba(15,31,61,0.08);
            --radius-sm: 6px;
            --radius-md: 12px;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background-color: var(--ivory);
        }

        .tl-navbar {
            background: rgba(255,255,255,0.97);
            padding: 0.85rem 0;
            box-shadow: var(--shadow-sm);
            border-bottom: 1px solid var(--border);
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
        }

            .tl-navbar .navbar-brand {
                font-family: 'Cormorant Garamond', serif;
                font-size: 1.65rem;
                font-weight: 700;
                color: #0a0f1f;
            }

                .tl-navbar .navbar-brand span {
                    color: var(--gold);
                }

        .page-hero {
            background: var(--navy);
            padding: 9rem 0 5rem;
            position: relative;
        }

        .page-hero-title {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(2.5rem, 5vw, 4rem);
            font-weight: 400;
            color: #faf8f3;
        }

        .inbox-card {
            background: var(--white);
            border-radius: var(--radius-md);
            box-shadow: var(--shadow-sm);
            overflow: hidden;
        }

        .conversation-item {
            display: flex;
            align-items: center;
            gap: 1rem;
            padding: 1rem 1.5rem;
            border-bottom: 1px solid var(--border);
            transition: all 0.2s ease;
            text-decoration: none;
            color: inherit;
        }

            .conversation-item:hover {
                background: var(--ivory);
            }

        .conversation-avatar {
            width: 50px;
            height: 50px;
            background: var(--gold);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 1.2rem;
            color: var(--navy);
            flex-shrink: 0;
        }

        .conversation-content {
            flex: 1;
        }

        .conversation-name {
            font-weight: 600;
            color: var(--navy);
            margin-bottom: 0.25rem;
        }

        .conversation-last-message {
            font-size: 0.85rem;
            color: #6c757d;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 300px;
        }

        .conversation-time {
            font-size: 0.7rem;
            color: #adb5bd;
            text-align: right;
        }

        .unread-badge {
            background: var(--gold);
            color: var(--navy);
            border-radius: 20px;
            padding: 0.2rem 0.6rem;
            font-size: 0.7rem;
            font-weight: 600;
        }

        .listing-thumb {
            width: 40px;
            height: 40px;
            object-fit: cover;
            border-radius: var(--radius-sm);
        }

        .empty-state {
            text-align: center;
            padding: 3rem;
        }

        footer {
            background: #0a1628;
            padding: 2rem 0;
            text-align: center;
            color: rgba(250,248,243,0.4);
            font-size: 0.85rem;
        }
    </style>
</head>
<body>

    <nav class="tl-navbar navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" href="/">Trust<span>Link</span></a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center gap-2">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Listings">Browse</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Listings/MyListings">My Listings</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/Messages/Inbox">Messages</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Account/Profile">Profile</a></li>
                    <li class="nav-item"><a class="btn-nav-cta" href="/Account/Logout">Sign Out</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <section class="page-hero">
        <div class="container">
            <div class="row">
                <div class="col-lg-8">
                    <h1 class="page-hero-title">My <em>Messages</em></h1>
                </div>
            </div>
        </div>
    </section>

    <section class="profile-section" style="padding: 4rem 0;">
        <div class="container">
            <div class="row">
                <div class="col-lg-8 mx-auto">
                    <div class="inbox-card">
                        @if (Model.Conversations == null || !Model.Conversations.Any())
                        {
                            <div class="empty-state">
                                <i class="bi bi-chat-dots" style="font-size: 3rem; color: #dee2e6;"></i>
                                <h3 class="mt-3">No messages yet</h3>
                                <p>Browse listings and message owners to start a conversation.</p>
                                <a href="/Listings" class="btn-primary-tl">Browse Listings</a>
                            </div>
                        }
                        else
                        {
                            foreach (var conv in Model.Conversations)
                            {
                                <a href="/Messages/Conversation?userId=@conv.OtherUserId&listingId=@conv.ListingId" class="conversation-item">
                                    <div class="conversation-avatar">
                                        @conv.OtherUserAvatar
                                    </div>
                                    <div class="conversation-content">
                                        <div class="conversation-name">
                                            @conv.OtherUserName
                                            @if (conv.UnreadCount > 0)
                                            {
                                                <span class="unread-badge ms-2">@conv.UnreadCount</span>
                                            }
                                        </div>
                                        <div class="conversation-last-message">
                                            @conv.LastMessage
                                        </div>
                                        @if (!string.IsNullOrEmpty(conv.ListingTitle))
                                        {
                                            <small class="text-muted">
                                                <i class="bi bi-box-seam"></i> @conv.ListingTitle
                                            </small>
                                        }
                                    </div>
                                    <div class="conversation-time">
                                        @conv.LastMessageAt.ToString("MMM dd")
                                    </div>
                                </a>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer>
        <div class="container">
            <p>&copy; 2024 TrustLink — Secure, documented peer exchanges.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>