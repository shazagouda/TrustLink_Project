@model SW_Project.Models.ContactMessage
@{
    ViewData["Title"] = "Contact Us - TrustLink";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/style.css">
</head>
<body>

    <!-- Navbar (نفس الـ Navbar الموجود في باقي الصفحات) -->
    <nav class="tl-navbar navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" href="/">Trust<span>Link</span></a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav ms-auto me-4 gap-1">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/About">About</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Home/HowItWorks">How It Works</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Listings">Browse</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/Contact">Contact</a></li>
                </ul>
                <div class="d-flex gap-2">
                    @if (User?.Identity?.IsAuthenticated == true)
                    {
                        <a href="/Listings/Create" class="btn-primary-tl" style="padding:0.55rem 1.25rem;font-size:0.85rem;">+ Post Listing</a>
                        <a href="/Listings/MyListings" class="btn-outline-tl">My Listings</a>
                        <a href="/Account/Profile" class="btn-outline-tl">Profile</a>
                        <a href="/Account/Logout" class="btn-nav-cta">Logout</a>
                    }
                    else
                    {
                        <a href="/Account/Login" class="btn-outline-tl">Sign In</a>
                        <a href="/Account/Register" class="btn-nav-cta">Get Started</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="page-hero">
        <div class="container">
            <div class="col-lg-7">
                <span class="page-hero-eyebrow fade-in-up">Contact</span>
                <h1 class="page-hero-title fade-in-up delay-1">Get in <em>touch</em> with us.</h1>
                <p class="page-hero-desc fade-in-up delay-2">Have a question, need help with a contract, or want to report an issue? Our team responds within one business day.</p>
            </div>
        </div>
    </section>

    <!-- Contact Form Section -->
    <section class="section-pad" style="background:var(--white);">
        <div class="container">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="row g-5">
                <!-- INFO LEFT -->
                <div class="col-lg-4 fade-in-up">
                    <div class="mb-5">
                        <span class="section-eyebrow">Reach Us</span>
                        <div class="divider-gold"></div>
                        <h2 class="section-title" style="font-size:1.8rem;">We're here to help</h2>
                        <p class="mt-3" style="font-size:0.9rem;color:var(--text-muted);">Whether you are a new user getting started or an existing member with a question about a contract or dispute, we are ready to assist.</p>
                    </div>

                    <div class="d-flex flex-column gap-4">
                        <!-- Email -->
                        <div style="display:flex;align-items:flex-start;gap:1rem;">
                            <div style="width:46px;height:46px;background:var(--navy);border-radius:10px;display:flex;align-items:center;justify-content:center;">
                                <i class="bi bi-envelope-fill" style="color:var(--gold);font-size:1.1rem;"></i>
                            </div>
                            <div>
                                <div style="font-weight:700;color:var(--navy);">Email</div>
                                <a href="mailto:support@trustlink.io" style="color:var(--text-muted);">support@trustlink.io</a>
                            </div>
                        </div>
                        <!-- Phone -->
                        <div style="display:flex;align-items:flex-start;gap:1rem;">
                            <div style="width:46px;height:46px;background:var(--navy);border-radius:10px;display:flex;align-items:center;justify-content:center;">
                                <i class="bi bi-telephone-fill" style="color:var(--gold);font-size:1.1rem;"></i>
                            </div>
                            <div>
                                <div style="font-weight:700;color:var(--navy);">Phone</div>
                                <div style="color:var(--text-muted);">+1 (800) 000-0000</div>
                            </div>
                        </div>
                        <!-- Office -->
                        <div style="display:flex;align-items:flex-start;gap:1rem;">
                            <div style="width:46px;height:46px;background:var(--navy);border-radius:10px;display:flex;align-items:center;justify-content:center;">
                                <i class="bi bi-geo-alt-fill" style="color:var(--gold);font-size:1.1rem;"></i>
                            </div>
                            <div>
                                <div style="font-weight:700;color:var(--navy);">Office</div>
                                <div style="color:var(--text-muted);">123 Commerce Street<br>New York, NY 10001</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- FORM RIGHT -->
                <div class="col-lg-8 fade-in-up delay-1">
                    <div style="background:var(--ivory);border:1px solid var(--border);border-radius:var(--radius-lg);padding:3rem;">
                        <h3 style="font-family:'Cormorant Garamond',serif;font-size:1.6rem;color:var(--navy);margin-bottom:0.5rem;">Send us a message</h3>
                        <p style="font-size:0.87rem;color:var(--text-muted);margin-bottom:2rem;">All fields marked with an asterisk (*) are required.</p>

                        <form method="post" asp-action="Send" asp-controller="Contact">
                            @Html.AntiForgeryToken()

                            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display: block;"></div>

                            <div class="form-row-tl">
                                <div class="form-group-tl">
                                    <label asp-for="FullName" class="form-label-tl">Full Name *</label>
                                    <input asp-for="FullName" class="form-input-tl" placeholder="Your full name" required />
                                    <span asp-validation-for="FullName" class="text-danger"></span>
                                </div>
                                <div class="form-group-tl">
                                    <label asp-for="Email" class="form-label-tl">Email Address *</label>
                                    <input asp-for="Email" class="form-input-tl" placeholder="you@example.com" required />
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="form-group-tl">
                                <label asp-for="Subject" class="form-label-tl">Subject *</label>
                                <select asp-for="Subject" class="form-input-tl" required>
                                    <option value="" disabled selected>Select a subject...</option>
                                    <option value="general">General Inquiry</option>
                                    <option value="contract">Contract Question</option>
                                    <option value="dispute">Dispute Report</option>
                                    <option value="listing">Listing Issue</option>
                                    <option value="account">Account Support</option>
                                    <option value="other">Other</option>
                                </select>
                                <span asp-validation-for="Subject" class="text-danger"></span>
                            </div>

                            <div class="form-group-tl">
                                <label asp-for="Message" class="form-label-tl">Message *</label>
                                <textarea asp-for="Message" rows="5" class="form-input-tl" placeholder="Describe your question or issue in detail..." required></textarea>
                                <span asp-validation-for="Message" class="text-danger"></span>
                            </div>

                            <div class="d-flex align-items-start gap-2 mb-3">
                                <input type="checkbox" asp-for="AgreePrivacy" required style="accent-color:var(--navy);width:15px;height:15px;margin-top:3px;">
                                <label asp-for="AgreePrivacy" style="font-size:0.82rem;color:var(--text-muted);">
                                    I agree that TrustLink may store and use my information to respond to this inquiry, in accordance with the <a href="#" style="color:var(--gold);">Privacy Policy</a>.
                                </label>
                            </div>
                            <span asp-validation-for="AgreePrivacy" class="text-danger"></span>

                            <button type="submit" class="submit-btn-tl" style="width:auto;padding:0.85rem 2.5rem;">
                                Send Message <i class="bi bi-send ms-2"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- FAQ Section -->
    <section class="section-pad" style="background:var(--ivory-dark);">
        <div class="container">
            <div class="text-center section-header fade-in-up" style="margin-bottom:3rem;">
                <span class="section-eyebrow">FAQ</span>
                <div class="divider-gold centered"></div>
                <h2 class="section-title">Common questions</h2>
            </div>
            <div class="row justify-content-center">
                <div class="col-lg-8 fade-in-up delay-1">
                    <div class="accordion" id="faqAccordion">
                        <!-- FAQ items (leave as original) -->
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#faq1">Are the digital contracts legally binding?</button>
                            </h2>
                            <div id="faq1" class="accordion-collapse collapse show" data-bs-parent="#faqAccordion">
                                <div class="accordion-body">Yes. TrustLink contracts are generated with full legal terms and electronically signed... </div>
                            </div>
                        </div>
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq2">What happens if a dispute arises?</button>
                            </h2>
                            <div id="faq2" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                                <div class="accordion-body">Either party can submit a dispute report... </div>
                            </div>
                        </div>
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq3">Is TrustLink free to use?</button>
                            </h2>
                            <div id="faq3" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                                <div class="accordion-body">Registration and browsing are free... </div>
                            </div>
                        </div>
                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#faq4">How is my personal data protected?</button>
                            </h2>
                            <div id="faq4" class="accordion-collapse collapse" data-bs-parent="#faqAccordion">
                                <div class="accordion-body">All user data is stored encrypted... </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer class="tl-footer">...</footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/script.js"></script>
</body>
</html>