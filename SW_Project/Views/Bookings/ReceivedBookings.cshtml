@model List<SW_Project.Models.Booking>
@using SW_Project.Models
@{
    ViewData["Title"] = "Received Bookings — TrustLink";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/style.css">
</head>
<body>

    <div class="d-flex gap-3 align-items-center">
        @if (User?.Identity?.IsAuthenticated == true)
        {
            <a href="/Listings/Create" class="btn-post-listing">+ Post Listing</a>
            <a href="/Listings/MyListings" class="nav-link-custom">My Listings</a>
            <a href="/Bookings/MyBookings" class="nav-link-custom">My Bookings</a>
            <a href="/Bookings/ReceivedBookings" class="nav-link-custom">Received Bookings</a>
            <a href="/Account/Profile" class="nav-link-custom">Profile</a>
            <a href="/Account/Logout" class="nav-link-custom">Logout</a>
        }
        else
        {
            <a href="/Account/Login" class="btn-outline-tl-nav">Sign In</a>
            <a href="/Account/Register" class="btn-nav-cta-nav">Get Started</a>
        }
    </div>

    <section class="page-hero" style="padding:8rem 0 3.5rem;">
        <div class="container">
            <div class="col-lg-8">
                <span class="page-hero-eyebrow">Owner Console</span>
                <h1 class="page-hero-title">Received <em>Bookings</em></h1>
                <p class="page-hero-desc">Manage booking requests for your listings.</p>
            </div>
        </div>
    </section>

    <section class="profile-section" style="padding:2rem 0 5rem;">
        <div class="container">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox" style="font-size: 4rem; color: var(--slate-light);"></i>
                    <h3>No pending requests</h3>
                    <p>When someone requests to book your listing, it will appear here.</p>
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var booking in Model)
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="profile-card">
                                <div class="profile-header" style="padding: 1rem;">
                                    <h3>@booking.Listing.Title</h3>
                                    <p>Renter: @booking.Renter.Name</p>
                                </div>
                                <div class="profile-body">
                                    <p><i class="bi bi-calendar-week"></i> @booking.StartDate.ToString("MMM dd") - @booking.EndDate.ToString("MMM dd, yyyy")</p>
                                    <p><strong>Total:</strong> $@booking.TotalPrice</p>
                                    <p><strong>Status:</strong> @booking.Status</p>
                                    @if (booking.Status == "Pending")
                                    {
                                        <form method="post" asp-action="UpdateStatus" asp-controller="Bookings" class="d-flex gap-2 mt-2">
                                            <input type="hidden" name="id" value="@booking.Id" />
                                            <button type="submit" name="status" value="Accepted" class="btn-primary-tl">Accept</button>
                                            <button type="submit" name="status" value="Rejected" class="btn-outline-tl">Reject</button>
                                        </form>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </section>

    <footer class="tl-footer">...</footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>