@using SW_Project.ViewModels.Listing
@model ListingCardVM
@{
    ViewData["Title"] = "Delete Listing - TrustLink";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-danger text-white">
                    <h3 class="mb-0">
                        <i class="bi bi-trash3-fill me-2"></i>
                        Delete Listing
                    </h3>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <strong>Warning!</strong> Are you sure you want to delete this listing?
                        This action can be reversed, but the listing will be hidden from public view.
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            @if (!string.IsNullOrEmpty(Model.MainImageUrl))
                            {
                                <img src="@Model.MainImageUrl" class="img-fluid rounded" alt="@Model.Title" style="width: 100%; height: 200px; object-fit: cover;">
                            }
                            else
                            {
                                <div class="bg-light rounded d-flex align-items-center justify-content-center" style="height: 200px;">
                                    <i class="bi bi-image text-muted" style="font-size: 3rem;"></i>
                                </div>
                            }
                        </div>
                        <div class="col-md-8">
                            <h3>@Model.Title</h3>
                            <p class="text-muted">
                                <i class="bi bi-geo-alt"></i> @Model.Location
                            </p>
                            <p class="text-muted">
                                <i class="bi bi-tag"></i> @Model.CategoryName
                            </p>
                            <h4 class="text-primary">$@Model.PricePerDay <small class="text-muted">/ day</small></h4>
                            @if (Model.Deposit.HasValue)
                            {
                                <p><strong>Deposit:</strong> $@Model.Deposit.Value</p>
                            }
                            <p class="mt-3">
                                <strong>Status:</strong>
                                <span class="badge @(Model.Status == "Available" ? "bg-success" : "bg-secondary")">
                                    @Model.Status
                                </span>
                            </p>
                            <p>
                                <strong>Created:</strong> @Model.CreatedAt.ToString("MMMM dd, yyyy")
                            </p>
                        </div>
                    </div>

                    <div class="mt-4 p-3 bg-light rounded">
                        <h6><i class="bi bi-info-circle"></i> What happens when you delete?</h6>
                        <ul class="mb-0 small">
                            <li>Your listing will be hidden from search results</li>
                            <li>Existing bookings will not be affected</li>
                            <li>You can restore your listing later if needed</li>
                            <li>This action is reversible (contact support for restore)</li>
                        </ul>
                    </div>
                </div>
                <div class="card-footer bg-white d-flex justify-content-between">
                    <form asp-action="Delete" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-check-lg"></i> Yes, Delete Listing
                        </button>
                        <a asp-action="MyListings" class="btn btn-secondary">
                            <i class="bi bi-x-lg"></i> Cancel
                        </a>
                    </form>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-primary">
                        <i class="bi bi-eye"></i> View Listing
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>