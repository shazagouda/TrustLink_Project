@model List<SW_Project.Models.Listing>
@using SW_Project.Models
@{
    ViewData["Title"] = "My Listings — TrustLink";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/style.css">
</head>
<body>

    <div class="d-flex gap-3 align-items-center">
        @if (User?.Identity?.IsAuthenticated == true)
        {
            <a href="/Listings/Create" class="btn-post-listing">+ Post Listing</a>
            <a href="/Listings/MyListings" class="nav-link-custom">My Listings</a>
            <a href="/Bookings/MyBookings" class="nav-link-custom">My Bookings</a>
            <a href="/Bookings/ReceivedBookings" class="nav-link-custom">Received Bookings</a>
            <a href="/Account/Profile" class="nav-link-custom">Profile</a>
            <a href="/Account/Logout" class="nav-link-custom">Logout</a>
        }
        else
        {
            <a href="/Account/Login" class="btn-outline-tl-nav">Sign In</a>
            <a href="/Account/Register" class="btn-nav-cta-nav">Get Started</a>
        }
    </div>
    <section class="page-hero" style="padding:8rem 0 3.5rem;">
        <div class="container">
            <div class="row">
                <div class="col-lg-8">
                    <span class="page-hero-eyebrow">My Account</span>
                    <h1 class="page-hero-title">My <em>Listings</em></h1>
                    <p class="page-hero-desc">All the items you have posted for rent.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="profile-section" style="padding:2rem 0 5rem;">
        <div class="container">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-box-seam" style="font-size: 4rem; color: var(--slate-light);"></i>
                    <h3>You haven't posted any listings yet</h3>
                    <p>Click the button below to share your first item.</p>
                    <a href="/Listings/Create" class="btn-primary-tl">+ Post a Listing</a>
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var listing in Model)
                    {
                        <div class="col-md-6 col-xl-4">
                            <div class="listing-card">
                                <div class="listing-card-image">
                                    @{
                                        var firstImage = listing.ListingImages?.FirstOrDefault();
                                    }
                                    @if (firstImage != null)
                                    {
                                        <img src="@firstImage.ImagePath" alt="@listing.Title" style="width:100%; height:100%; object-fit:cover;">
                                    }
                                    else
                                    {
                                        <div class="listing-card-image-placeholder">
                                            <i class="bi @(listing.Category?.Icon ?? "bi-box")"></i>
                                        </div>
                                    }
                                    <span class="listing-card-category">@(listing.Category?.Name ?? "General")</span>
                                </div>
                                <div class="listing-card-body">
                                    <div class="listing-card-title">@listing.Title</div>
                                    <div class="listing-card-location"><i class="bi bi-geo-alt"></i> @listing.Location</div>
                                    <div class="listing-card-footer">
                                        <div class="listing-card-price">$@listing.PricePerDay / day</div>
                                        <a href="/Listings/Details/@listing.Id" class="listing-card-btn">View Details</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </section>

    <footer class="tl-footer">...</footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/script.js"></script>
</body>
</html>