@model List<SW_Project.Models.Listing>
@using SW_Project.Models
@{
    ViewData["Title"] = "Browse Listings — TrustLink";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/style.css">
    <style>
        @@keyframes skeleton-pulse {
            0% { opacity: 1; }
            50% { opacity: 0.5; }
            100% { opacity: 1; }
        }
    </style>
</head>
<body>

    <div class="d-flex gap-3 align-items-center">
        @if (User?.Identity?.IsAuthenticated == true)
        {
            <a href="/Listings/Create" class="btn-post-listing">+ Post Listing</a>
            <a href="/Listings/MyListings" class="nav-link-custom">My Listings</a>
            <a href="/Favorites" class="nav-link-custom">Favorites</a>
            <a href="/Bookings/MyBookings" class="nav-link-custom">My Bookings</a>
            <a href="/Bookings/ReceivedBookings" class="nav-link-custom">Received Bookings</a>
            <a href="/Contracts/MyContracts" class="nav-link-custom">My Contracts</a>
            <a href="/Account/Profile" class="nav-link-custom">Profile</a>

            <a href="/Account/Logout" class="nav-link-custom">Logout</a>
        }
        else
        {
            <a href="/Account/Login" class="btn-outline-tl-nav">Sign In</a>
            <a href="/Account/Register" class="btn-nav-cta-nav">Get Started</a>
        }
    </div>

    <section class="page-hero" style="padding:8rem 0 3.5rem;">
        <div class="container">
            <div class="row align-items-end g-4">
                <div class="col-lg-7">
                    <span class="page-hero-eyebrow fade-in-up">Marketplace</span>
                    <h1 class="page-hero-title fade-in-up delay-1">Browse <em>available</em> listings</h1>
                    <p class="page-hero-desc fade-in-up delay-2">
                        Discover verified resources from trusted owners. Every listing is contract-enabled and review-backed.
                    </p>
                </div>
                <div class="col-lg-5 fade-in-up delay-2">
                    <form method="get" class="search-bar-wrapper">
                        <i class="bi bi-search"></i>
                        <input type="text" name="search" class="search-bar-input" placeholder="Search listings by name, location..." value="@ViewBag.Search">
                        <button type="submit" class="search-bar-btn">Search</button>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <section class="browse-section" style="padding:2.5rem 0 5rem;">
        <div class="container">
            <div class="category-pills fade-in-up">
                <a class="category-pill @(ViewBag.SelectedCategory == null ? "active" : "")" asp-route-category="" asp-route-page="1">
                    <i class="bi bi-grid-3x3-gap"></i> All Categories
                </a>
                @if (ViewBag.Categories != null && ((IEnumerable<Category>)ViewBag.Categories).Any())
                {
                    foreach (var cat in ViewBag.Categories as List<Category>)
                    {
                        <a class="category-pill @(ViewBag.SelectedCategory == cat.Id ? "active" : "")" asp-route-category="@cat.Id" asp-route-page="1">
                            <i class="bi @cat.Icon"></i> @cat.Name
                        </a>
                    }
                }
                else
                {
                    <div class="text-muted">Loading categories...</div>
                }
            </div>

            <div class="row g-4">
                <div class="col-lg-3">
                    <div class="filter-sidebar fade-in-up">
                        <div class="filter-heading">
                            Filters
                            <button class="filter-clear" type="button">Clear All</button>
                        </div>
                        <form method="get" id="filterForm">
                            <div class="filter-group">
                                <span class="filter-group-label">Price per Day</span>
                                <div class="price-range-input">
                                    <input type="number" name="minPrice" class="price-input-field" placeholder="Min" value="@ViewBag.MinPrice">
                                    <span class="price-separator">—</span>
                                    <input type="number" name="maxPrice" class="price-input-field" placeholder="Max" value="@ViewBag.MaxPrice">
                                </div>
                            </div>
                            <div class="filter-group">
                                <span class="filter-group-label">Location</span>
                                <input type="text" name="location" class="price-input-field" placeholder="City or area" value="@ViewBag.Location" style="width:100%;">
                            </div>
                            <input type="hidden" name="search" value="@ViewBag.Search">
                            <input type="hidden" name="category" value="@ViewBag.SelectedCategory">
                            <input type="hidden" name="sort" id="sortHidden" value="@ViewBag.Sort">
                            <button type="submit" class="apply-filter-btn">Apply Filters</button>
                        </form>
                    </div>
                </div>

                <div class="col-lg-9">
                    <div class="listings-toolbar fade-in-up">
                        <div class="listings-count">Showing <strong>@ViewBag.TotalListings</strong> listings</div>
                        <div class="toolbar-right">
                            <select class="sort-select" id="sortSelect">
                                <option value="newest" selected="@(ViewBag.Sort?.ToString() == "newest")">Newest First</option>
                                <option value="price-asc" selected="@(ViewBag.Sort?.ToString() == "price-asc")">Low to High</option>
                                <option value="price-desc" selected="@(ViewBag.Sort?.ToString() == "price-desc")">High to Low</option>
                            </select>
                            <div class="view-toggle">
                                <button class="view-toggle-btn active" data-view="grid"><i class="bi bi-grid-3x3-gap"></i></button>
                                <button class="view-toggle-btn" data-view="list"><i class="bi bi-list-ul"></i></button>
                            </div>
                        </div>
                    </div>

                    <div class="row g-4 listings-grid">
                        @if (!Model.Any())
                        {
                            <div class="listings-empty-state">No listings found. <button class="filter-clear">Clear Filters</button></div>
                        }
                        else
                        {
                    
                            var favoritedIds = ViewBag.FavoritedIds as List<int> ?? new List<int>();
                            foreach (var listing in Model)
                            {
                                var firstImage = listing.ListingImages?.FirstOrDefault();
                                var isFav = favoritedIds.Contains(listing.Id);
                                var isBooked = ViewBag.ActiveBookedIds != null && ((List<int>)ViewBag.ActiveBookedIds).Contains(listing.Id);
                                <div class="col-md-6 col-xl-4 listing-col">
                                    <div class="listing-card">
                                        <div class="listing-card-image">
                                            @if (firstImage != null)
                                            {
                                                <img src="@firstImage.ImagePath" alt="@listing.Title" style="width:100%; height:100%; object-fit:cover;">
                                            }
                                            else
                                            {
                                                <div class="listing-card-image-placeholder">
                                                    <i class="bi @(listing.Category?.Icon ?? "bi-box")"></i>
                                                </div>
                                            }
                                            <span class="listing-card-category">@(listing.Category?.Name ?? "General")</span>
                                            <button class="listing-card-favorite" data-id="@listing.Id">
                                                <i class="bi @(isFav ? "bi-heart-fill" : "bi-heart")"></i>
                                            </button>
                                        </div>
                                        <div class="listing-card-body">
                                            <div class="listing-card-title">@listing.Title</div>
                                            <div class="listing-card-location">
                                                <i class="bi bi-geo-alt"></i> @listing.Location
                                                @if (isBooked)
                                                {
                                                    <span style="float: right; background: #e67e22; color: white; padding: 2px 10px; border-radius: 15px; font-size: 0.7rem; font-weight: bold;">
                                                        🔴 BOOKED
                                                    </span>
                                                }
                                            </div>
                                            <div class="listing-card-footer">
                                                <div class="listing-card-price">$@listing.PricePerDay / day</div>
                                                <a href="/Listings/Details/@listing.Id" class="listing-card-btn">View Details</a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>

                    @if (ViewBag.TotalPages > 1)
                    {
                        <nav class="tl-pagination">
                            @for (int p = 1; p <= ViewBag.TotalPages; p++)
                            {
                                <a href="?page=@p&search=@ViewBag.Search&category=@ViewBag.SelectedCategory&location=@ViewBag.Location&minPrice=@ViewBag.MinPrice&maxPrice=@ViewBag.MaxPrice&sort=@ViewBag.Sort"
                                   class="tl-page-btn @(p == ViewBag.CurrentPage ? "active" : "")">@p</a>
                            }
                        </nav>
                    }
                </div>
            </div>
        </div>
    </section>

    <footer class="tl-footer">...</footer>
    <button id="back-to-top">...</button>

    @* ✅ إضافة AntiForgeryToken لطلبات AJAX *@
    @Html.AntiForgeryToken()

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/script.js"></script>
    <script>
        function showToast(msg, icon = 'bi-check-circle-fill') {
            let existing = document.querySelector('.tl-toast');
            if (existing) existing.remove();
            const t = document.createElement('div');
            t.className = 'tl-toast';
            t.innerHTML = `<i class="bi ${icon}"></i><span>${msg}</span>`;
            document.body.appendChild(t);
            requestAnimationFrame(() => {
                requestAnimationFrame(() => t.classList.add('show'));
            });
            setTimeout(() => {
                t.classList.remove('show');
                setTimeout(() => t.remove(), 400);
            }, 3500);
        }

        document.getElementById('sortSelect')?.addEventListener('change', function() {
            document.getElementById('sortHidden').value = this.value;
            document.getElementById('filterForm').submit();
        });
        document.querySelectorAll('.filter-clear').forEach(btn => {
            btn.addEventListener('click', () => window.location.href = '/Listings');
        });
        window.addEventListener('scroll', () => {
            const btn = document.getElementById('back-to-top');
            if (btn) btn.style.opacity = window.scrollY > 400 ? '1' : '0';
        });

        document.querySelectorAll('.listing-card-favorite').forEach(btn => {
            btn.addEventListener('click', async function(e) {
                e.preventDefault();
                e.stopPropagation();
                const listingId = this.dataset.id;
                const icon = this.querySelector('i');
                const isFav = icon.classList.contains('bi-heart-fill');
                const url = isFav ? '/Favorites/Remove' : '/Favorites/Add';
                const formData = new FormData();
                formData.append('listingId', listingId);
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                if (!token) {
                    console.error('Anti-forgery token not found');
                    return;
                }
                const response = await fetch(url, {
                    method: 'POST',
                    headers: { 'RequestVerificationToken': token },
                    body: formData
                });
                const result = await response.json();
                if (result.success) {
                    if (isFav) {
                        icon.classList.remove('bi-heart-fill');
                        icon.classList.add('bi-heart');
                    } else {
                        icon.classList.remove('bi-heart');
                        icon.classList.add('bi-heart-fill');
                    }
                    showToast(result.message);
                } else {
                    showToast(result.message, 'bi-x-circle');
                }
            });
        });
    </script>
</body>
</html>