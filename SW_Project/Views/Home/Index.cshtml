                </div>
                <div class="lcp-meta-item">
                  <span class="lcp-meta-label">Location</span>
                  <span class="lcp-meta-value" style="font-size:0.85rem;">New York, NY</span>
                </div>
              </div>
              <div class="lcp-divider"></div>
              <div class="lcp-footer">
                <div class="lcp-owner">
                  <div class="lcp-avatar">AH</div>
                  <div class="lcp-owner-info">
                    <span class="lcp-owner-name">Ahmed Hassan</span>
                    <span class="lcp-owner-rating">&#9733;&#9733;&#9733;&#9733;&#9733; 4.9</span>
                  </div>
                </div>
                <div class="lcp-contract-tag">
                  <div class="lcp-contract-icon"><i class="bi bi-file-earmark-check"></i></div>
