        <p class="mt-3" style="color:rgba(250,248,243,0.6); font-size:0.93rem; line-height:1.8;">
          Every feature is designed to eliminate friction while maximizing security. Whether you are lending equipment, renting space, or offering a service — TrustLink has you covered.
        </p>
        <div class="mt-4">
                    <a asp-action="About" class="btn-gold-tl">Learn About TrustLink <i class="bi bi-arrow-right ms-1"></i></a>
        </div>
      </div>
      <div class="col-lg-3 fade-in-up delay-1">
        <div class="feature-item">
          <div class="feature-icon"><i class="bi bi-shield-fill-check"></i></div>
          <div class="feature-text">
            <div class="feature-title">Digital Contracts</div>
            <p class="feature-desc">Auto-generated, legally binding agreements tailored to your specific transaction.</p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-icon"><i class="bi bi-pen-fill"></i></div>
          <div class="feature-text">
            <div class="feature-title">E-Signatures</div>
            <p class="feature-desc">Canvas-based signature capture with secure hash storage and timestamps.</p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-icon"><i class="bi bi-chat-square-dots-fill"></i></div>
          <div class="feature-text">
            <div class="feature-title">Secure Messaging</div>
            <p class="feature-desc">Communicate directly within the platform. All conversations are stored for reference.</p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-icon"><i class="bi bi-star-fill"></i></div>
          <div class="feature-text">
            <div class="feature-title">Review System</div>
            <p class="feature-desc">Bidirectional ratings after each transaction build a verifiable trust score.</p>
          </div>
        </div>
      </div>
      <div class="col-lg-4 fade-in-up delay-2">
        <div class="feature-visual-block">
          <div class="contract-preview-ui">
            <div class="cpu-header">
              <div class="cpu-title">Rental Agreement</div>
              <div class="cpu-status">Active</div>
            </div>
            <div class="cpu-field">
              <span class="cpu-field-label">Item</span>
              <div class="cpu-field-value">Sony A7 IV Camera</div>
            </div>
            <div class="cpu-field">
              <span class="cpu-field-label">Duration</span>
              <div class="cpu-field-value">Nov 12 – Nov 15, 2024</div>
            </div>
            <div class="cpu-field">
              <span class="cpu-field-label">Total Agreed Price</span>
              <div class="cpu-field-value" style="color:var(--gold-light); font-weight:600;">$150.00 + $200 deposit</div>
            </div>
            <div class="cpu-signature-area">
              <div>
                <div class="cpu-sig-label">Party A — Owner</div>
                <div class="cpu-sig-signed"><i class="bi bi-check-circle-fill"></i> Signed</div>
              </div>
              <div>
                <div class="cpu-sig-label">Party B — Renter</div>
                <div class="cpu-sig-signed"><i class="bi bi-check-circle-fill"></i> Signed</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>


<section class="listings-section section-pad">
    <div class="container">
        <div class="row justify-content-between align-items-end section-header mb-4">
            <div class="col-lg-6 fade-in-up">
                <span class="section-eyebrow">Recent Listings</span>
                <div class="divider-gold"></div>
                <h2 class="section-title">Available right now</h2>
            </div>
            <div class="col-lg-auto fade-in-up delay-1">
                <a href="/Listings" class="btn-outline-tl">Browse All <i class="bi bi-arrow-right ms-1"></i></a>
            </div>
        </div>

        <div class="row g-4">
            @if (Model != null && Model.Any())
            {
                @foreach (var listing in Model)
                {
                    <div class="col-md-6 col-lg-4 fade-in-up delay-1">
                        <div class="listing-card" data-category="@listing.CategoryId">
                            <div class="listing-card-image">
                                @{
                                    var firstImage = listing.ListingImages?.FirstOrDefault();
                                }
                                @if (firstImage != null)
                                {
                                    <img src="@firstImage.ImagePath" alt="@listing.Title" loading="lazy" style="width:100%; height:100%; object-fit:cover;">
                                }
                                else
                                {
                                    <div class="listing-card-image-placeholder">
                                        <i class="bi @(listing.Category?.Icon ?? "bi-box")"></i>
                                    </div>
                                }
                                <span class="listing-card-category">@(listing.Category?.Name ?? "General")</span>
                                <button class="listing-card-favorite" data-id="@listing.Id">
                                    <i class="bi bi-heart"></i>
                                </button>
                            </div>
                            <div class="listing-card-body">
                                <div class="listing-card-title">@listing.Title</div>
                                <div class="listing-card-location"><i class="bi bi-geo-alt"></i> @listing.Location</div>
                                <div class="listing-card-footer">
                                    <div class="listing-card-price">
                                        <span class="price-amount">$@listing.PricePerDay</span>
                                        <span class="price-period">/ day</span>
                                    </div>
                                    <a href="/Listings/Details/@listing.Id" class="listing-card-btn">View Details</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <i class="bi bi-box-seam" style="font-size: 3rem; color: var(--slate-light);"></i>
                    <p class="mt-2">No listings available at the moment. Please check back later.</p>
                </div>
            }
        </div>
    </div>
</section>

