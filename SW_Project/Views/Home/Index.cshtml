      <div class="trust-bar-item"><i class="bi bi-star"></i> Verified Reviews</div>
      <div class="trust-bar-item"><i class="bi bi-bell"></i> Real-time Notifications</div>
      <!-- duplicate for seamless loop -->
      <div class="trust-bar-item"><i class="bi bi-shield-check"></i> Legally Binding Digital Contracts</div>
      <div class="trust-bar-item"><i class="bi bi-pen"></i> Electronic Signature</div>
      <div class="trust-bar-item"><i class="bi bi-chat-dots"></i> Built-in Secure Messaging</div>
      <div class="trust-bar-item"><i class="bi bi-file-earmark-pdf"></i> Auto-generated PDF Records</div>
      <div class="trust-bar-item"><i class="bi bi-star"></i> Verified Reviews</div>
      <div class="trust-bar-item"><i class="bi bi-bell"></i> Real-time Notifications</div>
    </div>
  </div>
</div>

<!-- HOW IT WORKS PREVIEW -->
<section class="how-preview-section section-pad">
  <div class="container">
    <div class="row justify-content-center text-center section-header">
      <div class="col-lg-7">
        <span class="section-eyebrow fade-in-up">The Process</span>
        <div class="divider-gold centered"></div>
        <h2 class="section-title fade-in-up delay-1">From listing to signed contract in minutes</h2>
        <p class="mt-3 fade-in-up delay-2" style="color:var(--text-muted); font-size:0.95rem; line-height:1.8;">
          TrustLink streamlines every step of peer-to-peer rentals — eliminating informal handshakes and replacing them with documented, enforceable agreements.
        </p>
      </div>
    </div>
    <div class="row g-4">
      <div class="col-md-6 col-lg-3 fade-in-up delay-1">
        <div class="how-step-card">
          <div class="how-step-number">01</div>
          <div class="how-step-icon"><i class="bi bi-plus-lg"></i></div>
          <div class="how-step-title">List Your Asset</div>
          <p class="how-step-desc">Post your item or service with photos, pricing, deposit requirements, and availability dates.</p>
        </div>
      </div>
      <div class="col-md-6 col-lg-3 fade-in-up delay-2">
        <div class="how-step-card">
          <div class="how-step-number">02</div>
          <div class="how-step-icon"><i class="bi bi-chat-dots"></i></div>
          <div class="how-step-title">Connect &amp; Agree</div>
          <p class="how-step-desc">Chat securely with the other party. Negotiate price, duration, and terms before committing.</p>
        </div>
      </div>
      <div class="col-md-6 col-lg-3 fade-in-up delay-3">
        <div class="how-step-card">
          <div class="how-step-number">03</div>
          <div class="how-step-icon"><i class="bi bi-file-earmark-check"></i></div>
          <div class="how-step-title">Sign the Contract</div>
          <p class="how-step-desc">The platform generates a legal contract automatically. Both parties sign electronically — no lawyers needed.</p>
        </div>
      </div>
      <div class="col-md-6 col-lg-3 fade-in-up delay-4">
        <div class="how-step-card">
          <div class="how-step-number">04</div>
          <div class="how-step-icon"><i class="bi bi-star"></i></div>
          <div class="how-step-title">Review &amp; Close</div>
          <p class="how-step-desc">After the rental, both parties leave verified reviews. Ratings build credibility for future transactions.</p>
        </div>
      </div>
    </div>
    <div class="text-center mt-5 fade-in-up">
      <a href="how-it-works.html" class="btn-outline-tl">View Full Process <i class="bi bi-arrow-right ms-1"></i></a>
    </div>
  </div>
</section>

<!-- FEATURES -->
