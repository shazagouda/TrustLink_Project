          <div class="hero-float-badge hero-float-badge-1">
            <div class="hfb-icon"><i class="bi bi-shield-check"></i></div>
            <div class="hfb-text">
              <span class="hfb-label">Contract Status</span>
              <span class="hfb-value">Signed &amp; Active</span>
            </div>
          </div>
          <div class="hero-float-badge hero-float-badge-2">
