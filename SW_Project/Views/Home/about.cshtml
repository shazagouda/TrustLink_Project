@{
    ViewData["Title"] = "About Us - TrustLink";
}
<!-- PAGE HERO -->
<section class="page-hero">
  <div class="container">
    <div class="row align-items-center g-5">
      <div class="col-lg-7">
        <span class="page-hero-eyebrow fade-in-up">About TrustLink</span>
        <h1 class="page-hero-title fade-in-up delay-1">
          Redefining trust<br>in the <em>sharing economy.</em>
        </h1>
        <p class="page-hero-desc fade-in-up delay-2">
          TrustLink was built on a simple conviction: peer-to-peer exchanges deserve the same documentation and protection as formal business contracts — without the friction.
        </p>
      </div>
      
            
            </div>
          </div>
    
</section>

<!-- STORY -->
<section class="about-intro-section section-pad">
  <div class="container">
    <div class="row align-items-center g-5">
      <div class="col-lg-5 fade-in-up">
        <span class="section-eyebrow">Our Story</span>
        <div class="divider-gold"></div>
        <h2 class="section-title">The problem we set out to solve</h2>
        <p class="mt-3" style="color:var(--text-muted); line-height:1.9; font-size:0.93rem;">
          Every day, thousands of informal peer exchanges happen — a camera borrowed, a workshop tool lent, freelance work agreed upon with just a text message. When things go wrong, there is nothing to fall back on.
        </p>
        <p class="mt-3" style="color:var(--text-muted); line-height:1.9; font-size:0.93rem;">
          TrustLink was born from this gap. We built a platform where every transaction, regardless of scale, can be backed by a real, enforceable digital contract — with zero legal overhead for the end user.
        </p>
      </div>
      <div class="col-lg-7 fade-in-up delay-1">
        <div class="about-story-block">
          <div class="large-quote">
            "Ahmed had a camera. Sara needed one. They should not need a lawyer to make that work — they needed TrustLink."
          </div>
          <div class="mt-3" style="font-size:0.85rem;color:var(--text-muted);">
            — The founding principle behind TrustLink
          </div>
        </div>
        <div class="row g-3 mt-3">
          <div class="col-6">
            <div style="background:var(--white);border:1px solid var(--border);border-radius:10px;padding:1.25rem;display:flex;align-items:center;gap:1rem;">
              <div style="width:44px;height:44px;background:var(--navy);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;"><i class="bi bi-shield-check" style="color:var(--gold);font-size:1.1rem;"></i></div>
              <div>
                <div style="font-weight:700;color:var(--navy);font-size:0.9rem;">Legal Protection</div>
                <div style="font-size:0.78rem;color:var(--text-muted);">For every user</div>
              </div>
            </div>
          </div>
          <div class="col-6">
            <div style="background:var(--white);border:1px solid var(--border);border-radius:10px;padding:1.25rem;display:flex;align-items:center;gap:1rem;">
              <div style="width:44px;height:44px;background:var(--navy);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;"><i class="bi bi-people-fill" style="color:var(--gold);font-size:1.1rem;"></i></div>
              <div>
                <div style="font-weight:700;color:var(--navy);font-size:0.9rem;">Community First</div>
                <div style="font-size:0.78rem;color:var(--text-muted);">Built on reviews</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- VALUES -->
<section class="section-pad" style="background:var(--ivory-dark);">
  <div class="container">
    <div class="text-center section-header fade-in-up">
      <span class="section-eyebrow">Our Values</span>
      <div class="divider-gold centered"></div>
      <h2 class="section-title">What guides everything we build</h2>
    </div>
    <div class="row g-4">
      <div class="col-md-6 col-lg-4 fade-in-up delay-1">
        <div class="about-value-card">
          <div class="about-value-icon"><i class="bi bi-shield-fill-check"></i></div>
          <div class="about-value-title">Trust by Default</div>
          <p class="about-value-desc">Every feature is designed to build, verify, and protect trust between strangers. We do not assume good faith — we engineer it.</p>
        </div>
      </div>
      <div class="col-md-6 col-lg-4 fade-in-up delay-2">
        <div class="about-value-card">
          <div class="about-value-icon"><i class="bi bi-transparency"></i></div>
          <div class="about-value-title">Radical Transparency</div>
          <p class="about-value-desc">Pricing, terms, and expectations are made explicit before any agreement is signed. No hidden clauses, no verbal ambiguity.</p>
        </div>
      </div>
      <div class="col-md-6 col-lg-4 fade-in-up delay-3">
        <div class="about-value-card">
          <div class="about-value-icon"><i class="bi bi-unlock-fill"></i></div>
          <div class="about-value-title">Accessible Law</div>
          <p class="about-value-desc">Legal-grade documentation should not require a law degree. We make binding contracts available to anyone, in minutes.</p>
        </div>
      </div>
      <div class="col-md-6 col-lg-4 fade-in-up delay-1">
        <div class="about-value-card">
          <div class="about-value-icon"><i class="bi bi-people-fill"></i></div>
          <div class="about-value-title">Community Over Commerce</div>
          <p class="about-value-desc">TrustLink exists to facilitate real human connections, not just transactions. Reviews, ratings, and reputations are central to who we are.</p>
        </div>
      </div>
      <div class="col-md-6 col-lg-4 fade-in-up delay-2">
        <div class="about-value-card">
          <div class="about-value-icon"><i class="bi bi-lightning-fill"></i></div>
          <div class="about-value-title">Frictionless Speed</div>
          <p class="about-value-desc">Contracts are generated automatically. Signatures take seconds. From agreement to PDF in under a minute — always.</p>
        </div>
      </div>
      <div class="col-md-6 col-lg-4 fade-in-up delay-3">
        <div class="about-value-card">
          <div class="about-value-icon"><i class="bi bi-lock-fill"></i></div>
          <div class="about-value-title">Data Integrity</div>
          <p class="about-value-desc">Every signature, timestamp, and agreement is stored securely. Your records are tamper-evident and permanently accessible.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- MISSION / VISION -->
<section class="section-pad" style="background:var(--navy);position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background-image:linear-gradient(rgba(201,168,76,0.03)1px,transparent 1px),linear-gradient(90deg,rgba(201,168,76,0.03)1px,transparent 1px);background-size:60px 60px;"></div>
  <div class="container" style="position:relative;z-index:2;">
    <div class="row g-5">
      <div class="col-lg-6 fade-in-up">
        <span class="section-eyebrow">Mission</span>
        <div class="divider-gold"></div>
        <h2 class="section-title" style="color:var(--ivory);">To make every exchange worth trusting.</h2>
        <p class="mt-3" style="color:rgba(250,248,243,0.6);line-height:1.9;font-size:0.93rem;">
          Our mission is to eliminate the risk and uncertainty that holds people back from sharing their valuable assets and skills. We provide the infrastructure of trust so that anyone can transact confidently with anyone else.
        </p>
      </div>
      <div class="col-lg-6 fade-in-up delay-1">
        <span class="section-eyebrow">Vision</span>
        <div class="divider-gold"></div>
        <h2 class="section-title" style="color:var(--ivory);">A world where peer trust is verifiable.</h2>
        <p class="mt-3" style="color:rgba(250,248,243,0.6);line-height:1.9;font-size:0.93rem;">
          We envision a future where no resource goes underutilized because owners fear informal arrangements — and no renter is left unprotected by a lack of documentation. TrustLink is the layer that makes that possible.
        </p>
      </div>
    </div>
  </div>
</section>


<!-- CTA -->

<section class="cta-section section-pad">
    <div class="container">
        <div class="fade-in-up">
            <h2 class="cta-title">Start renting <em>smarter</em> today.</h2>
            <p class="cta-desc">Join thousands of users who have replaced informal handshakes with documented, enforceable digital agreements.</p>
            <div class="d-flex gap-3 justify-content-center flex-wrap">
                <a asp-controller="Account" asp-action="Register" class="btn-gold-tl">Create Free Account <i class="bi bi-arrow-right ms-1"></i></a>
                <a asp-controller="Listings" asp-action="Index" class="btn-hero-secondary">Explore Listings</a>
            </div>
        </div>
    </div>
</section>

