@{
    ViewData["Title"] = "How It Works - TrustLink";
}
<!-- PAGE HERO -->
<section class="page-hero">
  <div class="container">
    <div class="col-lg-8">
      <span class="page-hero-eyebrow fade-in-up">The TrustLink Process</span>
      <h1 class="page-hero-title fade-in-up delay-1">
        From first contact<br>to <em>signed agreement</em> — in minutes.
      </h1>
      <p class="page-hero-desc fade-in-up delay-2">
        A step-by-step walkthrough of how TrustLink turns a casual peer exchange into a documented, enforceable digital contract.
      </p>
    </div>
  </div>
</section>

<!-- OVERVIEW CARDS -->
<section class="section-pad-sm" style="background:var(--white);">
  <div class="container">
    <div class="row g-3">
      <div class="col-6 col-md-3 fade-in-up delay-1">
        <div style="text-align:center;padding:1.75rem 1rem;background:var(--ivory);border:1px solid var(--border);border-radius:12px;">
          <div style="width:52px;height:52px;background:var(--navy);border-radius:10px;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;"><i class="bi bi-person-plus-fill" style="color:var(--gold);font-size:1.3rem;"></i></div>
          <div style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:1rem;color:var(--navy);">Register</div>
          <div style="font-size:0.78rem;color:var(--text-muted);margin-top:0.3rem;">Create your account</div>
        </div>
      </div>
      <div class="col-6 col-md-3 fade-in-up delay-2">
        <div style="text-align:center;padding:1.75rem 1rem;background:var(--ivory);border:1px solid var(--border);border-radius:12px;">
          <div style="width:52px;height:52px;background:var(--navy);border-radius:10px;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;"><i class="bi bi-card-list" style="color:var(--gold);font-size:1.3rem;"></i></div>
          <div style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:1rem;color:var(--navy);">List or Browse</div>
          <div style="font-size:0.78rem;color:var(--text-muted);margin-top:0.3rem;">Post or find assets</div>
        </div>
      </div>
      <div class="col-6 col-md-3 fade-in-up delay-3">
        <div style="text-align:center;padding:1.75rem 1rem;background:var(--ivory);border:1px solid var(--border);border-radius:12px;">
          <div style="width:52px;height:52px;background:var(--navy);border-radius:10px;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;"><i class="bi bi-file-earmark-text-fill" style="color:var(--gold);font-size:1.3rem;"></i></div>
          <div style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:1rem;color:var(--navy);">Sign Contract</div>
          <div style="font-size:0.78rem;color:var(--text-muted);margin-top:0.3rem;">E-sign in seconds</div>
        </div>
      </div>
      <div class="col-6 col-md-3 fade-in-up delay-4">
        <div style="text-align:center;padding:1.75rem 1rem;background:var(--ivory);border:1px solid var(--border);border-radius:12px;">
          <div style="width:52px;height:52px;background:var(--navy);border-radius:10px;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;"><i class="bi bi-star-fill" style="color:var(--gold);font-size:1.3rem;"></i></div>
          <div style="font-family:'Cormorant Garamond',serif;font-weight:600;font-size:1rem;color:var(--navy);">Review</div>
          <div style="font-size:0.78rem;color:var(--text-muted);margin-top:0.3rem;">Build your reputation</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- DETAILED STEPS -->
<section class="hiw-section section-pad">
  <div class="container">
    <div class="row">
      <div class="col-lg-8 mx-auto">

        <div class="hiw-step">
          <div class="hiw-step-left">
            <div class="hiw-step-num">01</div>
            <div class="hiw-step-line"></div>
          </div>
          <div class="hiw-step-right">
            <span class="hiw-step-tag">Getting Started</span>
            <h3 class="hiw-step-title">Register or Log In</h3>
            <p class="hiw-step-desc">Create your TrustLink account with a verified email address. ASP.NET Identity ensures your credentials are secure from day one. New users receive a profile with a trust score that grows with each successful transaction.</p>
            <div class="hiw-step-detail">
              <strong>What the system does:</strong> Validates your email, creates a session, assigns a secure JWT token, and initializes your trust profile with default settings.
            </div>
          </div>
        </div>

        <div class="hiw-step">
          <div class="hiw-step-left">
            <div class="hiw-step-num">02</div>
            <div class="hiw-step-line"></div>
          </div>
          <div class="hiw-step-right">
            <span class="hiw-step-tag">For Owners</span>
            <h3 class="hiw-step-title">Create a Listing</h3>
            <p class="hiw-step-desc">Post your item or service with full details: title, category, description, price per day, optional deposit, location, and photos. Your listing goes live immediately with a status of "Available."</p>
            <div class="hiw-step-detail">
              <strong>Supported categories:</strong> Electronics, Tools, Vehicles, Spaces, Services, Photography, Audio/Video, and more.
            </div>
          </div>
        </div>

        <div class="hiw-step">
          <div class="hiw-step-left">
            <div class="hiw-step-num">03</div>
            <div class="hiw-step-line"></div>
          </div>
          <div class="hiw-step-right">
            <span class="hiw-step-tag">For Renters</span>
            <h3 class="hiw-step-title">Browse &amp; Discover</h3>
            <p class="hiw-step-desc">Search and filter listings by price range, location, category, and availability. Each listing displays the owner's rating, verified reviews, and contract status. Save favorites to revisit later.</p>
            <div class="hiw-step-detail">
              <strong>Smart search:</strong> Results are returned based on price filters, proximity, category, and owner rating — so you always see the most relevant listings first.
            </div>
          </div>
        </div>

        <div class="hiw-step">
          <div class="hiw-step-left">
            <div class="hiw-step-num">04</div>
            <div class="hiw-step-line"></div>
          </div>
          <div class="hiw-step-right">
            <span class="hiw-step-tag">Communication</span>
            <h3 class="hiw-step-title">Chat &amp; Negotiate</h3>
            <p class="hiw-step-desc">Use TrustLink's built-in secure messaging to communicate directly with the owner or renter. Negotiate terms, confirm dates, and agree on responsibilities — all within the platform with a full message history.</p>
            <div class="hiw-step-detail">
              <strong>All messages are stored</strong> and can be referenced later if any dispute arises. Notifications keep both parties informed in real time.
            </div>
          </div>
        </div>

        <div class="hiw-step">
          <div class="hiw-step-left">
            <div class="hiw-step-num">05</div>
            <div class="hiw-step-line"></div>
          </div>
          <div class="hiw-step-right">
            <span class="hiw-step-tag">Legal Layer</span>
            <h3 class="hiw-step-title">Contract is Generated</h3>
            <p class="hiw-step-desc">Once terms are agreed upon, TrustLink automatically generates a digital contract. It includes the item description, rental period, agreed price, deposit details, and specific responsibilities for both parties.</p>
            <div class="hiw-step-detail">
              <strong>Contract status:</strong> Starts as "Draft." Both parties can review and propose edits before the signature phase begins. Once finalized, status moves to "Pending."
            </div>
          </div>
        </div>

        <div class="hiw-step">
          <div class="hiw-step-left">
            <div class="hiw-step-num">06</div>
            <div class="hiw-step-line"></div>
          </div>
          <div class="hiw-step-right">
            <span class="hiw-step-tag">E-Signature</span>
            <h3 class="hiw-step-title">Both Parties Sign</h3>
            <p class="hiw-step-desc">Each party signs using a canvas-based electronic signature tool (powered by signature_pad.js). Signatures are stored as secure Base64 PNG hashes with a cryptographic timestamp. Once both sign, the contract becomes "Active."</p>
            <div class="hiw-step-detail">
              <strong>What is locked:</strong> The item's availability is blocked for the agreed dates. A PDF copy of the signed contract is generated and sent to both parties.
            </div>
          </div>
        </div>

        <div class="hiw-step">
          <div class="hiw-step-left">
            <div class="hiw-step-num">07</div>
            <div class="hiw-step-line"></div>
          </div>
          <div class="hiw-step-right">
            <span class="hiw-step-tag">Execution</span>
            <h3 class="hiw-step-title">Complete the Rental</h3>
            <p class="hiw-step-desc">The rental or service proceeds according to the signed contract. Both parties have a PDF record they can reference at any time. If any issue arises, the signed contract serves as legally admissible proof of the agreed terms.</p>
            <div class="hiw-step-detail">
              <strong>Dispute resolution:</strong> The Admin team can review the signed contract, messages, and booking history to mediate any reported issues.
            </div>
          </div>
        </div>

        <div class="hiw-step">
          <div class="hiw-step-left">
            <div class="hiw-step-num">08</div>
          </div>
          <div class="hiw-step-right">
            <span class="hiw-step-tag">Closing the Loop</span>
            <h3 class="hiw-step-title">Review &amp; Build Reputation</h3>
            <p class="hiw-step-desc">After completion, both parties leave a verified review (rating 1–5 with a comment). Reviews are linked to specific bookings — no fake reviews. Your average rating updates automatically and is displayed on your profile and all your listings.</p>
            <div class="hiw-step-detail">
              <strong>Bidirectional reviews:</strong> The owner rates the renter, and the renter rates the owner. This creates a two-way accountability system that rewards reliable users.
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- ROLES SECTION -->
<section class="section-pad" style="background:var(--ivory-dark);">
  <div class="container">
    <div class="text-center section-header fade-in-up">
      <span class="section-eyebrow">User Roles</span>
      <div class="divider-gold centered"></div>
      <h2 class="section-title">Who uses TrustLink</h2>
    </div>
    <div class="row g-4">
      <div class="col-md-4 fade-in-up delay-1">
        <div style="background:var(--white);border:1px solid var(--border);border-radius:14px;padding:2.25rem;height:100%;transition:var(--transition);" onmouseover="this.style.boxShadow='var(--shadow-md)'" onmouseout="this.style.boxShadow='none'">
          <div style="width:56px;height:56px;background:var(--gold-pale);border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:1.5rem;"><i class="bi bi-person-fill" style="color:var(--gold);font-size:1.4rem;"></i></div>
          <div style="font-family:'Cormorant Garamond',serif;font-size:1.35rem;font-weight:600;color:var(--navy);margin-bottom:0.75rem;">Regular User</div>
          <p style="font-size:0.88rem;color:var(--text-muted);line-height:1.8;margin-bottom:1.25rem;">Browse listings, request bookings, sign contracts as a renter, leave reviews, and manage their favorites and message history.</p>
          <ul style="list-style:none;padding:0;">
            <li style="font-size:0.82rem;color:var(--text-body);padding:0.3rem 0;border-bottom:1px solid var(--border);display:flex;gap:0.5rem;align-items:center;"><i class="bi bi-check2" style="color:var(--gold);"></i> Browse &amp; search listings</li>
            <li style="font-size:0.82rem;color:var(--text-body);padding:0.3rem 0;border-bottom:1px solid var(--border);display:flex;gap:0.5rem;align-items:center;"><i class="bi bi-check2" style="color:var(--gold);"></i> Book and pay for rentals</li>
            <li style="font-size:0.82rem;color:var(--text-body);padding:0.3rem 0;border-bottom:1px solid var(--border);display:flex;gap:0.5rem;align-items:center;"><i class="bi bi-check2" style="color:var(--gold);"></i> Sign digital contracts</li>
            <li style="font-size:0.82rem;color:var(--text-body);padding:0.3rem 0;display:flex;gap:0.5rem;align-items:center;"><i class="bi bi-check2" style="color:var(--gold);"></i> Rate other parties</li>
          </ul>
        </div>
      </div>
      <div class="col-md-4 fade-in-up delay-2">
        <div style="background:var(--navy);border:1px solid rgba(201,168,76,0.2);border-radius:14px;padding:2.25rem;height:100%;position:relative;overflow:hidden;">
          <div style="position:absolute;top:-30px;right:-30px;width:100px;height:100px;background:rgba(201,168,76,0.06);border-radius:50%;"></div>
          <div style="width:56px;height:56px;background:rgba(201,168,76,0.15);border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:1.5rem;"><i class="bi bi-box-seam-fill" style="color:var(--gold);font-size:1.4rem;"></i></div>
          <div style="font-family:'Cormorant Garamond',serif;font-size:1.35rem;font-weight:600;color:var(--ivory);margin-bottom:0.75rem;">Owner / Provider</div>
          <p style="font-size:0.88rem;color:rgba(250,248,243,0.6);line-height:1.8;margin-bottom:1.25rem;">List items or services, manage bookings and availability, negotiate terms, and sign contracts as the providing party.</p>
          <ul style="list-style:none;padding:0;">
            <li style="font-size:0.82rem;color:rgba(250,248,243,0.8);padding:0.3rem 0;border-bottom:1px solid rgba(250,248,243,0.08);display:flex;gap:0.5rem;align-items:center;"><i class="bi bi-check2" style="color:var(--gold);"></i> Create and manage listings</li>
            <li style="font-size:0.82rem;color:rgba(250,248,243,0.8);padding:0.3rem 0;border-bottom:1px solid rgba(250,248,243,0.08);display:flex;gap:0.5rem;align-items:center;"><i class="bi bi-check2" style="color:var(--gold);"></i> Accept or reject bookings</li>
            <li style="font-size:0.82rem;color:rgba(250,248,243,0.8);padding:0.3rem 0;border-bottom:1px solid rgba(250,248,243,0.08);display:flex;gap:0.5rem;align-items:center;"><i class="bi bi-check2" style="color:var(--gold);"></i> Sign contracts as Party A</li>
            <li style="font-size:0.82rem;color:rgba(250,248,243,0.8);padding:0.3rem 0;display:flex;gap:0.5rem;align-items:center;"><i class="bi bi-check2" style="color:var(--gold);"></i> View earnings history</li>
          </ul>
        </div>
      </div>
      <div class="col-md-4 fade-in-up delay-3">
        <div style="background:var(--white);border:1px solid var(--border);border-radius:14px;padding:2.25rem;height:100%;">
          <div style="width:56px;height:56px;background:var(--gold-pale);border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:1.5rem;"><i class="bi bi-shield-fill" style="color:var(--gold);font-size:1.4rem;"></i></div>
          <div style="font-family:'Cormorant Garamond',serif;font-size:1.35rem;font-weight:600;color:var(--navy);margin-bottom:0.75rem;">Administrator</div>
          <p style="font-size:0.88rem;color:var(--text-muted);line-height:1.8;margin-bottom:1.25rem;">Oversee the full platform. Manage users, review flagged listings, adjudicate disputes using contract evidence, and maintain platform integrity.</p>
          <ul style="list-style:none;padding:0;">
            <li style="font-size:0.82rem;color:var(--text-body);padding:0.3rem 0;border-bottom:1px solid var(--border);display:flex;gap:0.5rem;align-items:center;"><i class="bi bi-check2" style="color:var(--gold);"></i> Full user management</li>
            <li style="font-size:0.82rem;color:var(--text-body);padding:0.3rem 0;border-bottom:1px solid var(--border);display:flex;gap:0.5rem;align-items:center;"><i class="bi bi-check2" style="color:var(--gold);"></i> Review all contracts</li>
            <li style="font-size:0.82rem;color:var(--text-body);padding:0.3rem 0;border-bottom:1px solid var(--border);display:flex;gap:0.5rem;align-items:center;"><i class="bi bi-check2" style="color:var(--gold);"></i> Handle dispute reports</li>
            <li style="font-size:0.82rem;color:var(--text-body);padding:0.3rem 0;display:flex;gap:0.5rem;align-items:center;"><i class="bi bi-check2" style="color:var(--gold);"></i> Moderate listings</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-section section-pad">
    <div class="container">
        <div class="fade-in-up">
            <h2 class="cta-title">Start renting <em>smarter</em> today.</h2>
            <p class="cta-desc">Join thousands of users who have replaced informal handshakes with documented, enforceable digital agreements.</p>
            <div class="d-flex gap-3 justify-content-center flex-wrap">
                <a asp-controller="Account" asp-action="Register" class="btn-gold-tl">Create Free Account <i class="bi bi-arrow-right ms-1"></i></a>
                <a asp-controller="Listings" asp-action="Index" class="btn-hero-secondary">Explore Listings</a>
            </div>
        </div>
    </div>
</section>
